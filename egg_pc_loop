def crop_ocr_region(client_bgr: np.ndarray) -> np.ndarray:
    h, w = client_bgr.shape[:2]

    left = int(w * OCR_LEFT_RATIO)
    top = int(h * OCR_TOP_RATIO)
    width = int(w * OCR_WIDTH_RATIO)
    height = int(h * OCR_HEIGHT_RATIO)

    right = min(w, left + width)
    bottom = min(h, top + height)

    return client_bgr[top:bottom, left:right]


def preprocess_for_ocr(img_bgr: np.ndarray) -> np.ndarray:
    gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
    gray = cv2.resize(gray, None, fx=2.5, fy=2.5, interpolation=cv2.INTER_CUBIC)
    gray = cv2.bilateralFilter(gray, 7, 40, 40)

    th = cv2.adaptiveThreshold(
        gray,
        255,
        cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
        cv2.THRESH_BINARY,
        31,
        11
    )
    return th


def dialog_box_likely_present(client_bgr: np.ndarray) -> bool:
    roi = crop_ocr_region(client_bgr)
    gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)

    mean_val = float(np.mean(gray))
    bright_ratio = float(np.mean(gray > 170))

    return mean_val > 80 and bright_ratio > 0.18


def extract_text_from_rapidocr_result(result) -> str:
    parts = []

    if not result:
        return ""

    for item in result:
        try:
            if len(item) >= 3 and isinstance(item[1], str):
                parts.append(item[1])
                continue

            if len(item) >= 2 and isinstance(item[1], (list, tuple)) and len(item[1]) >= 1:
                parts.append(str(item[1][0]))
                continue

            if len(item) >= 2:
                parts.append(str(item[1]))
        except Exception:
            continue

    return normalize_text(" ".join(parts))


