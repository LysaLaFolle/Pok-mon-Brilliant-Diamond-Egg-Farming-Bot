    npc = locate_template(scene, NPC_TEMPLATE_PATH, threshold=NPC_TEMPLATE_THRESHOLD)

    if npc is None:
        print("[CALIB] Tentative 2 : PNJ avec seuil plus tolérant...")
        npc = locate_template(scene, NPC_TEMPLATE_PATH, threshold=RECALIB_NPC_THRESHOLD)

    if npc is None:
        print("[ERREUR] PNJ non détecté pendant la calibration.")
        print("=> Vérifie npc.png ou baisse encore le threshold.")
        return False

    player = locate_player_for_calibration(
        scene,
        npc,
        threshold=PLAYER_TEMPLATE_THRESHOLD
    )

    save_debug_scene(scene, npc, player, prefix="calibration")

    if player is None:
        print("[WARN] Joueur non détecté dans la ROI de calibration.")
        print("Calibration PNJ seule conservée.")

        REFERENCE_CALIBRATION = {
            "npc_x": npc["x"],
            "npc_y": npc["y"],
            "player_x": None,
            "player_y": None,
            "offset_x": None,
            "offset_y": None,
            "player_detected": False,
        }

        print(f"[CALIB] PNJ=({npc['x']},{npc['y']}) | mode=PNJ-seul\n")
        return True

    dx = player["x"] - npc["x"]
    dy = player["y"] - npc["y"]

    print(f"[CALIB] Vérification joueur dx={dx} dy={dy} score={player['score']:.3f}")

    if dx < CALIB_PLAYER_MIN_DX or dx > CALIB_PLAYER_MAX_DX or dy < CALIB_PLAYER_MIN_DY or dy > CALIB_PLAYER_MAX_DY:
        print(f"[WARN] Joueur détecté mais NON PLAUSIBLE pour calibration dx={dx} dy={dy}")
        print("Calibration PNJ seule conservée.")

        REFERENCE_CALIBRATION = {
            "npc_x": npc["x"],
            "npc_y": npc["y"],
            "player_x": None,
            "player_y": None,
            "offset_x": None,
            "offset_y": None,
            "player_detected": False,
        }

        print(f"[CALIB] PNJ=({npc['x']},{npc['y']}) | mode=PNJ-seul\n")
        return True

    REFERENCE_CALIBRATION = {
        "npc_x": npc["x"],
        "npc_y": npc["y"],
        "player_x": player["x"],
        "player_y": player["y"],
        "offset_x": dx,
        "offset_y": dy,
        "player_detected": True,
    }

    print(
        f"[CALIB] SUCCESS | "
        f"PNJ=({npc['x']},{npc['y']}) | "
        f"JOUEUR=({player['x']},{player['y']}) | "
        f"offset_x={dx} offset_y={dy}\n"
    )

    return True


