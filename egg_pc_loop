def crop_scene_region(client_bgr: np.ndarray) -> np.ndarray:
    h, w = client_bgr.shape[:2]

    left = int(w * SCENE_LEFT_RATIO)
    top = int(h * SCENE_TOP_RATIO)
    width = int(w * SCENE_WIDTH_RATIO)
    height = int(h * SCENE_HEIGHT_RATIO)

    right = min(w, left + width)
    bottom = min(h, top + height)

    return client_bgr[top:bottom, left:right]


def locate_template(haystack_bgr: np.ndarray, template_path: str, threshold: float = 0.80):
    template = cv2.imread(template_path, cv2.IMREAD_COLOR)
    if template is None:
        raise RuntimeError(f"Template introuvable: {template_path}")

    haystack_gray = cv2.cvtColor(haystack_bgr, cv2.COLOR_BGR2GRAY)
    template_gray = cv2.cvtColor(template, cv2.COLOR_BGR2GRAY)

    result = cv2.matchTemplate(haystack_gray, template_gray, cv2.TM_CCOEFF_NORMED)
    _, max_val, _, max_loc = cv2.minMaxLoc(result)

    print(f"[VISION] {os.path.basename(template_path)} score={max_val:.3f} threshold={threshold:.3f}")

    if max_val < threshold:
        return None

    th, tw = template_gray.shape[:2]
    center_x = max_loc[0] + tw // 2
    center_y = max_loc[1] + th // 2

    return {
        "score": max_val,
        "x": center_x,
        "y": center_y,
        "top_left": max_loc,
        "w": tw,
        "h": th,
        "template_path": template_path,
    }


def locate_best_player_template(haystack_bgr: np.ndarray, template_paths, threshold: float):
    best_match = None
    best_score = -1.0

    if haystack_bgr is None or haystack_bgr.size == 0:
        print("[VISION] haystack joueur vide.")
        return None

    haystack_gray = cv2.cvtColor(haystack_bgr, cv2.COLOR_BGR2GRAY)
    hh, hw = haystack_gray.shape[:2]

    for template_path in template_paths:
        template = cv2.imread(template_path, cv2.IMREAD_COLOR)
        if template is None:
            print(f"[VISION] template joueur introuvable: {template_path}")
            continue

        template_gray = cv2.cvtColor(template, cv2.COLOR_BGR2GRAY)
        th, tw = template_gray.shape[:2]

        if th > hh or tw > hw:
            print(
                f"[VISION] {os.path.basename(template_path)} ignoré "
                f"(template trop grand pour ROI: template={tw}x{th}, roi={hw}x{hh})"
            )
            continue

        result = cv2.matchTemplate(haystack_gray, template_gray, cv2.TM_CCOEFF_NORMED)
        _, max_val, _, max_loc = cv2.minMaxLoc(result)

        print(f"[VISION] {os.path.basename(template_path)} score={max_val:.3f} threshold={threshold:.3f}")

        if max_val > best_score:
            best_score = max_val
            best_match = {
                "score": max_val,
                "x": max_loc[0] + tw // 2,
                "y": max_loc[1] + th // 2,
                "top_left": max_loc,
                "w": tw,
                "h": th,
                "template_path": template_path,
            }

    if best_match is not None:
        print(
            f"[VISION] Best joueur match: "
            f"{os.path.basename(best_match['template_path'])} "
            f"score={best_match['score']:.3f} "
            f"pos=({best_match['x']},{best_match['y']})"
        )

    if best_match is None:
        return None

    if best_match["score"] < threshold:
        return None

    return best_match


def locate_best_player_template_in_roi(
    haystack_bgr: np.ndarray,
    template_paths,
    roi_left: int,
    roi_top: int,
    roi_right: int,
    roi_bottom: int,
    threshold: float
):
    h, w = haystack_bgr.shape[:2]

    roi_left = max(0, roi_left)
    roi_top = max(0, roi_top)
    roi_right = min(w, roi_right)
    roi_bottom = min(h, roi_bottom)

    if roi_right <= roi_left or roi_bottom <= roi_top:
        print("[VISION] ROI joueur invalide.")
        return None

    roi = haystack_bgr[roi_top:roi_bottom, roi_left:roi_right]

    if roi is None or roi.size == 0:
        print("[VISION] ROI joueur vide.")
        return None

    rh, rw = roi.shape[:2]
    print(f"[VISION] ROI joueur taille: {rw}x{rh}")

    best_match = locate_best_player_template(roi, template_paths, threshold)

    if best_match is None:
        return None

    best_match["x"] += roi_left
    best_match["y"] += roi_top

    x1, y1 = best_match["top_left"]
    best_match["top_left"] = (x1 + roi_left, y1 + roi_top)

    return best_match


def save_debug_scene(scene_bgr: np.ndarray, npc, player, prefix: str = "scene"):
    if not DEBUG_VISION:
        return

    ensure_dir(DEBUG_VISION_DIR)
    img = scene_bgr.copy()

    if npc is not None:
        x1, y1 = npc["top_left"]
        x2, y2 = x1 + npc["w"], y1 + npc["h"]
        cv2.rectangle(img, (x1, y1), (x2, y2), (0, 255, 0), 2)
        cv2.putText(
            img,
            f"NPC {npc['score']:.2f}",
            (x1, max(20, y1 - 10)),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.5,
            (0, 255, 0),
            1,
        )

    if player is not None:
        x1, y1 = player["top_left"]
        x2, y2 = x1 + player["w"], y1 + player["h"]
        label = os.path.basename(player.get("template_path", "player"))
        cv2.rectangle(img, (x1, y1), (x2, y2), (255, 0, 0), 2)
        cv2.putText(
            img,
            f"{label} {player['score']:.2f}",
            (x1, max(20, y1 - 10)),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.5,
            (255, 0, 0),
            1,
        )

    path = os.path.join(DEBUG_VISION_DIR, f"{timestamp_str()}_{prefix}.png")
    cv2.imwrite(path, img)


def locate_player_for_calibration(scene_bgr: np.ndarray, npc, threshold: float):
    if npc is None:
        return None

    roi_left = npc["x"] + CALIB_PLAYER_MIN_DX - CALIB_PLAYER_ROI_MARGIN_X
    roi_top = npc["y"] + CALIB_PLAYER_MIN_DY - CALIB_PLAYER_ROI_MARGIN_Y
    roi_right = npc["x"] + CALIB_PLAYER_MAX_DX + CALIB_PLAYER_ROI_MARGIN_X
    roi_bottom = npc["y"] + CALIB_PLAYER_MAX_DY + CALIB_PLAYER_ROI_MARGIN_Y

    print(
        f"[CALIB] ROI joueur calibration: "
        f"({roi_left},{roi_top})-({roi_right},{roi_bottom})"
    )

    return locate_best_player_template_in_roi(
        scene_bgr,
        PLAYER_TEMPLATE_PATHS,
        roi_left,
        roi_top,
        roi_right,
        roi_bottom,
        threshold=threshold
    )


