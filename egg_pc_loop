def find_ryujinx_hwnd() -> Optional[int]:
    hwnds = []

    def callback(hwnd, _):
        if not win32gui.IsWindowVisible(hwnd):
            return True

        title = win32gui.GetWindowText(hwnd)
        if not title:
            return True

        try:
            _, pid = win32process.GetWindowThreadProcessId(hwnd)
            proc_name = psutil.Process(pid).name().lower()
        except Exception:
            return True

        if "ryujinx" in title.lower() or "ryujinx" in proc_name:
            hwnds.append(hwnd)

        return True

    win32gui.EnumWindows(callback, None)
    return hwnds[0] if hwnds else None


def get_ryujinx_client_rect_on_screen(hwnd: int):
    left, top, right, bottom = win32gui.GetClientRect(hwnd)
    x1, y1 = win32gui.ClientToScreen(hwnd, (left, top))
    x2, y2 = win32gui.ClientToScreen(hwnd, (right, bottom))
    return x1, y1, x2, y2


def grab_ryujinx_client_bgr() -> np.ndarray:
    hwnd = find_ryujinx_hwnd()
    if hwnd is None:
        raise RuntimeError("Fenêtre Ryujinx introuvable.")

    x1, y1, x2, y2 = get_ryujinx_client_rect_on_screen(hwnd)
    width = x2 - x1
    height = y2 - y1

    if width <= 0 or height <= 0:
        raise RuntimeError("Zone client Ryujinx invalide.")

    with mss.mss() as sct:
        shot = np.array(sct.grab({
            "left": x1,
            "top": y1,
            "width": width,
            "height": height,
        }))

    return cv2.cvtColor(shot, cv2.COLOR_BGRA2BGR)


