def read_dialog_text_once() -> str:
    client = grab_ryujinx_client_bgr()
    roi = crop_ocr_region(client)
    proc = preprocess_for_ocr(roi)

    result, _ = OCR(proc)
    text = extract_text_from_rapidocr_result(result)

    if DEBUG_OCR:
        print(f"[OCR] {text}")

    save_debug_ocr_images(client, roi, proc, text)
    return text


def read_dialog_text() -> str:
    best_text = ""

    for attempt in range(OCR_READ_RETRIES):
        text = read_dialog_text_once()

        if len(text) > len(best_text):
            best_text = text

        if len(text) >= 10:
            return text

        if attempt < OCR_READ_RETRIES - 1:
            time.sleep(OCR_READ_RETRY_DELAY)

    return best_text


def read_dialog_text_from_client(client: np.ndarray) -> str:
    roi = crop_ocr_region(client)
    proc = preprocess_for_ocr(roi)

    result, _ = OCR(proc)
    text = extract_text_from_rapidocr_result(result)

    if DEBUG_OCR:
        print(f"[OCR] {text}")

    return text


def is_dialog_open(text: str) -> bool:
    if not text:
        return False

    t = text.strip()

    if len(t) < 10:
        return False

    letters = sum(1 for c in t if c.isalpha())
    digits = sum(1 for c in t if c.isdigit())

    if letters < 6:
        return False

    if digits > letters:
        return False

    words = [w for w in t.split() if len(w) >= 2]
    if len(words) < 3:
        return False

    junk_chars = set("il1|/\\v")
    junk_count = sum(1 for c in t.lower() if c in junk_chars)
    significant_chars = sum(1 for c in t if not c.isspace())

    if significant_chars > 0 and (junk_count / significant_chars) > 0.55:
        return False

    return True


def looks_like_real_dialog(text: str) -> bool:
    if not text:
        return False

    common_dialog_words = [
        "toi",
        "pokemon",
        "oeuf",
        "surprises",
        "content",
        "voir",
        "viens",
        "reviens",
        "encore",
        "pension",
        "beau",
        "matin",
        "tenait",
        "avait",
        "tes",
        "des",
        "une",
        "pas",
    ]

    hits = sum(1 for word in common_dialog_words if word in text)
    return hits >= 1


def detect_dialog_state_from_text(text: str) -> Optional[str]:
    if not text:
        return None

    egg_markers_strong = [
        "tenait un oeuf",
        "voici un oeuf",
        "un oeuf a ete trouve",
        "avait un oeuf",
        "oeuf pokemon",
        "tes pokemon",
        "fait de ces surprises",
    ]

    egg_markers_soft = [
        "un oeuf",
        "oeuf",
        "surprises",
        "beau matin",
        "pension",
        "tes pokemon",
        "une",
    ]

    no_egg_markers = [
        "content de te voir",
        "reviens me voir",
        "viens me voir",
        "pas encore",
        "aucun oeuf",
        "pas d oeuf",
        "reviens plus tard",
    ]

    if any(marker in text for marker in egg_markers_strong):
        return "egg"

    egg_soft_hits = sum(1 for marker in egg_markers_soft if marker in text)
    if egg_soft_hits >= 2:
        return "egg"

    no_egg_hits = sum(1 for marker in no_egg_markers if marker in text)
    if no_egg_hits >= 1 and egg_soft_hits == 0:
        return "no_egg"

    return None


