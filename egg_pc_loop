def fallback_dialog_search_reset(controller: Controller):
    print("[RECALIB] Reset unique: 5 gauche, 4 bas, 5 droite, 2 haut, pad gauche")

    move_left(controller, 5)
    time.sleep(0.25)

    move_down(controller, 4)
    time.sleep(0.25)

    move_right(controller, 9)
    time.sleep(0.25)

    move_up(controller, 2)
    time.sleep(0.25)

    dpad_left(controller, hold=0.12, wait=0.12)
    time.sleep(0.15)


