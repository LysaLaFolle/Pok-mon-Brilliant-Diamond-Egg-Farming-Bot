def normalize_text(s: str) -> str:
    s = s.lower()
    s = unicodedata.normalize("NFKD", s)
    s = "".join(ch for ch in s if not unicodedata.combining(ch))
    s = s.replace("’", " ")
    s = s.replace("'", " ")
    s = s.replace("`", " ")
    s = re.sub(r"[^a-z0-9!\?\s]", " ", s)
    s = re.sub(r"\s+", " ", s).strip()
    return s


def ensure_dir(path: str):
    os.makedirs(path, exist_ok=True)


def timestamp_str() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S_%f")


def stick_macro(x: int, y: int, hold: float, wait: float = 0.0) -> str:
    return f"L_STICK@{x:+04d}{y:+04d} {hold:.3f}s {wait:.3f}s"


def move_right(controller: Controller, count: int = 1):
    for _ in range(count):
        controller.macro(stick_macro(AMPLITUDE, 0, MOVE_HOLD, MOVE_WAIT))


def move_left(controller: Controller, count: int = 1):
    for _ in range(count):
        controller.macro(stick_macro(-AMPLITUDE, 0, MOVE_HOLD, MOVE_WAIT))


def move_up(controller: Controller, count: int = 1):
    for _ in range(count):
        controller.macro(stick_macro(0, +AMPLITUDE, MOVE_HOLD, MOVE_WAIT))


def move_down(controller: Controller, count: int = 1):
    for _ in range(count):
        controller.macro(stick_macro(0, -AMPLITUDE, MOVE_HOLD, MOVE_WAIT))


def face_left(controller: Controller):
    controller.macro(stick_macro(-AMPLITUDE, 0, 0.08, 0.10))


def dpad_left(controller: Controller, hold: float = 0.10, wait: float = 0.10):
    controller.macro(f"DPAD_LEFT {hold:.2f}s {wait:.2f}s")


def press_button(controller: Controller, button: str, hold: float = 0.18, wait: float = 0.30):
    controller.macro(f"{button} {hold:.2f}s {wait:.2f}s")


def press_many(controller: Controller, button: str, count: int, hold: float = 0.18, wait: float = 0.30):
    for _ in range(count):
        press_button(controller, button, hold=hold, wait=wait)


def do_egg_steps(controller: Controller):
