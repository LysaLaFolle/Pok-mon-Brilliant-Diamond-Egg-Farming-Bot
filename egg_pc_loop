def try_interact_and_read_dialog(controller: Controller):
    face_left(controller)
    time.sleep(FACE_TO_INTERACT_DELAY)

    press_button(controller, INTERACT_BUTTON, hold=0.18, wait=0.35)
    time.sleep(POST_INTERACT_DELAY)

    client = grab_ryujinx_client_bgr()

    if not dialog_box_likely_present(client):
        return False, None, ""

    text = read_dialog_text_from_client(client)

    if not is_dialog_open(text):
        return False, None, text

    if looks_like_real_dialog(text):
        state = detect_dialog_state_from_text(text)
        return True, state, text

    return False, None, text


def interact_with_npc_and_resolve(controller: Controller):
    print("Recherche du PNJ : un petit pas, une tentative...")

    for attempt in range(RECENTER_MAX_ATTEMPTS):
        move_left(controller, 1)
        time.sleep(STEP_TO_INTERACT_DELAY)

        dialog_open, state, text = try_interact_and_read_dialog(controller)

        if dialog_open:
            if DEBUG_OCR:
                print(f"[INFO] Vrai dialogue détecté | OCR='{text}' | state={state}")

            if state == "egg":
                handle_egg_dialog(controller)
                return "egg"

            if state == "no_egg":
                handle_no_egg_dialog(controller)
                return "no_egg"

            if DEBUG_OCR:
                print("[INFO] Dialogue valide détecté mais aucun mot-clé reconnu.")
            return "dialog_unrecognized"

        if DEBUG_OCR:
            print(f"[INFO] Petit pas {attempt + 1}/{RECENTER_MAX_ATTEMPTS} : pas de vrai dialogue | OCR='{text}'")

    print("PNJ non trouvé après tous les petits pas.")
    return None


