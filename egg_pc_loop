# MAIN
# =========================================================
def main():
    controller = Controller()
    failed_dialog_cycles = 0

    print("\n=== CONFIGURATION MANETTE ===")
    print(f"Tu as {CONTROLLER_SETUP_DELAY} secondes pour sélectionner")
    print("la manette Xbox virtuelle dans Ryujinx.")
    print("Laisse Ryujinx visible sur l'écran secondaire.\n")
    time.sleep(CONTROLLER_SETUP_DELAY)

    print(f"Démarrage dans {START_DELAY} secondes...\n")
    time.sleep(START_DELAY)

    ok = calibrate_reference_positions()
    if not ok:
        print("Calibration impossible. Arrêt du programme.")
        return

    print("Bot lancé. Ctrl+C pour arrêter.\n")

    while True:
        move_right(controller, INITIAL_RIGHT_TAPS)
        do_egg_steps(controller)

        result = interact_with_npc_and_resolve(controller)

        if result in ("egg", "no_egg"):
            failed_dialog_cycles = 0
        else:
            failed_dialog_cycles += 1
            print(f"[WARN] Echec de dialogue ({failed_dialog_cycles}/{VISION_RECALIB_FAIL_THRESHOLD})")

        if failed_dialog_cycles >= VISION_RECALIB_FAIL_THRESHOLD:
            fallback_dialog_search_reset(controller)
            failed_dialog_cycles = 0


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nArrêt demandé.")
